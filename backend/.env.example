# Google Gemini (free tier: high-volume defaults on AI Studio)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite
# Heavier reasoning: GEMINI_MODEL=gemini-2.5-flash
# Extra models to try on 429/404 (comma-separated). Avoid unversioned gemini-1.5-flash (often 404 on v1beta).
# Example: GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash
#
# Vision-only primary model (Chinese handwriting / OCR): tried before built-in fallbacks; leave empty to use GEMINI_MODEL.
# Use a different Flash id if lite hits quota but another model still has headroom:
# GEMINI_VISION_MODEL=gemini-2.0-flash
#
# When Gemini quota is exhausted: text endpoints fall through to Groq → Hugging Face → Ollama if keys/serving are set.
# Vision endpoints require Gemini unless you add another multimodal provider in code.

# Groq (free tier: llama-3.1-8b-instant — very high RPM on dev tier)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# Vision fallback when Gemini is over quota — requires Groq multimodal preview model:
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Hugging Face Inference API (free tier; gemma-2-2b is lightweight and widely hosted)
HF_API_TOKEN=
# HF_CHAT_MODEL=google/gemma-2-2b-it

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# Local vision fallback (handwriting/OCR): pull first, e.g. `ollama pull llama3.2-vision`
# OLLAMA_VISION_MODEL=llama3.2-vision

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
# Optional (Database → Database password in dashboard, for direct Postgres clients only)
# SUPABASE_DATABASE_PASSWORD=

# CORS
CORS_ORIGINS=["http://localhost:3000"]
